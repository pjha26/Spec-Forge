# SpecForge — Self-hosted environment configuration
# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://specforge:changeme@localhost:5432/specforge
POSTGRES_PASSWORD=changeme

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-long-random-string

# ── AI Providers (provide at least one) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# ── Optional integrations ────────────────────────────────────────────────────
# Notion Internal Integration token (from notion.so/my-integrations)
NOTION_API_KEY=secret_...

# ── OIDC Auth (Replit Auth by default) ───────────────────────────────────────
ISSUER_URL=https://replit.com/oidc
# For custom OIDC (self-hosted): set your own ISSUER_URL

# ── Public URL (used for SAML SP metadata & OAuth callbacks) ─────────────────
PUBLIC_URL=https://specforge.example.com

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=8080
