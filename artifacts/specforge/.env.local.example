# SpecForge frontend — local development overrides
# Copy this file to artifacts/specforge/.env.local
# Vite picks it up automatically; never commit the real .env.local

# Show the "LOCAL DEV MODE" banner in the app and skip Replit Auth UI.
# Must match LOCAL_DEV=true on the API server.
VITE_LOCAL_DEV=true

# Should match LOCAL_DEV_USER_ID on the API server.
# Shown in the dev-mode banner so you know which mock user is active.
VITE_LOCAL_DEV_USER_ID=local-dev-user
